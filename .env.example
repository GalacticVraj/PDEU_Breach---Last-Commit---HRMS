# ==========================================
# TalentOS Environment Variables Profile
# Rename this file to .env before running
# ==========================================

# SERVER/BACKEND SETTINGS
PORT=5000
DATABASE_URL=postgresql://postgres:password@localhost:5432/talentos
REDIS_URL=redis://localhost:6379
JWT_SECRET=super_secret_jwt_string_123

# ANTHROPIC AI SETTINGS (Required for Resume Parsing & Semantic Search)
# Get a key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# EXTERNAL INTEGRATIONS
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret
HRMS_API_KEY=your_workday_greenhouse_key

# FRONTEND SETTINGS (Should be mirrored in /client/.env)
VITE_API_BASE_URL=http://localhost:5000/api
