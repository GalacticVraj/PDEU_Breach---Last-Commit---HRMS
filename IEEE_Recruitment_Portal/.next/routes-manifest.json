      "namedRegex": "^/candidates(?:/)?$"
    },
    {
      "page": "/candidates/add",
      "regex": "^/candidates/add(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/candidates/add(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/guide",
      "regex": "^/guide(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/guide(?:/)?$"
    },
    {
      "page": "/interview",
      "regex": "^/interview(?:/)?$",
