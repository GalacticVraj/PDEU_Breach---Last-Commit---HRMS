      "namedRegex": "^/interview(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/members",
      "regex": "^/members(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/members(?:/)?$"
    },
    {
      "page": "/members/add",
      "regex": "^/members/add(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/members/add(?:/)?$"
    },
    {
      "page": "/qbank",
