# HireX — .gitignore
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Dependencies
node_modules/

# Build output
client/dist/
client/.vite/

# Environment variables (NEVER commit these)
.env
.env.local
.env.production
server/.env
client/.env

# Logs
*.log
npm-debug.log*
yarn-debug.log*

# OS Files
.DS_Store
Thumbs.db

# TypeScript
*.tsbuildinfo

# AI model cache (downloaded automatically at runtime)
server/.cache/
