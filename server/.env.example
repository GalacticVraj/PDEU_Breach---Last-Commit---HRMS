# HireX Backend - Deployment Config
PORT=3001
GROQ_API_KEY=your_groq_api_key_here
JWT_SECRET=your_jwt_secret_here

# Gmail SMTP (For sending resumes/offers)
GMAIL_USER=your.email@gmail.com
