# HireX Backend Environment Variables

# ==========================================
# GMAIL SMTP CONFIGURATION
# ==========================================
# To send actual emails with PDF attachments from your normal Gmail account:
# 1. Enter your Gmail address below.
# 2. Go to your Google Account Settings -> Security
# 3. Enable 2-Step Verification if not already enabled.
# 4. Search for "App Passwords" and create a new one for "HireX".
# 5. Paste the 16-character password below (NO SPACES).
#
# Note: If these are left blank, the system will fall back to using Ethereal (mock emails).

GMAIL_USER=your.email@gmail.com
GMAIL_PASS=xxxx_xxxx_xxxx_xxxx
